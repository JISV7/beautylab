# BeautyLab Backend Environment Variables
# Copy this file to .env and fill in your values

# ==================== Application ====================
APP_NAME=BeautyLab API
DEBUG=false

# ==================== Database ====================
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/beautylab

# ==================== JWT Security ====================
# Generate a strong secret key for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ==================== Argon2 Password Hashing ====================
# Memory cost (default: 65536)
ARGON2_MEMORY_COST=65536
# Time cost (default: 3)
ARGON2_TIME_COST=3
# Parallelism (default: 4)
ARGON2_PARALLELISM=4

# ==================== Email (SMTP) ====================
# Gmail SMTP Configuration
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password (not your regular password) below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Codyn Academy

# ==================== Company Info ====================
COMPANY_NAME="Codyn - The Online Programming and AI Academy"
SUPPORT_EMAIL=support@codyn.com
PAYMENTS_EMAIL=payments@codyn.com
WEBSITE_URL=http://localhost:5173
